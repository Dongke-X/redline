{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDesc__",
  "version": "0.1.5",
  "default_locale": "en",
  "author": "dk",
  "homepage_url": "https://github.com/Dongke-X/redline",
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_icon": {
      "16": "icons/redline-16.png",
      "48": "icons/redline-48.png",
      "128": "icons/redline-128.png"
    }
  },
  "icons": {
    "16": "icons/redline-16.png",
    "48": "icons/redline-48.png",
    "128": "icons/redline-128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "redline.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
